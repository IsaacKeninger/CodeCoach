{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "CodeCoach",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "CodeCoach"
  },
  "runtimes": [
    {
      "name": "CodeCoachAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/CodeCoachAgent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [
    {
      "name": "CodeCoachMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaces": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaces": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaces": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaces": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": []
}